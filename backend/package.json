{
  "name": "lomashwood-backend",
  "version": "1.0.0",
  "description": "Microservices backend for Lomash Wood website",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "db:seed": "turbo run db:seed",
    "docker:dev": "docker-compose -f infra/docker/docker-compose.yml up",
    "docker:prod": "docker-compose -f infra/docker/docker-compose.production.yml up"
  },
  "keywords": ["lomashwood", "backend", "api", "cms"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^1.13.3",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
